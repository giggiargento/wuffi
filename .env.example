# ─────────────────────────────────────────────────────────────
# WUFFI — Firebase (Expo public env vars)
# Copy this file to `.env` and fill in values from Firebase Console.
# ─────────────────────────────────────────────────────────────
#
# Where to find each value:
# Firebase Console → Project Settings (⚙️) → General → Your apps → Web app
# Or run after `firebase login`:
#   npx firebase-tools@latest apps:sdkconfig WEB --project YOUR_PROJECT_ID
#
# Paste each field from the Firebase web config object:

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — maps (not required for auth MVP)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Firebase Console mapping ──
# apiKey              → EXPO_PUBLIC_FIREBASE_API_KEY
# authDomain          → EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN
# projectId           → EXPO_PUBLIC_FIREBASE_PROJECT_ID
# storageBucket       → EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET
# messagingSenderId   → EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
# appId               → EXPO_PUBLIC_FIREBASE_APP_ID
